# Credenciales MySQL compartidas entre las BDs por dominio
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_USER=admin
MYSQL_PASSWORD=change_this_mysql_password

# Nombre de base lógica por microservicio (database-per-service)
MYSQL_DATABASE_USUARIOS=usuarios_db
MYSQL_DATABASE_TIENDAS=tiendas_db
MYSQL_DATABASE_CATALOGO=catalogo_db
MYSQL_DATABASE_MEDIA=media_db
MYSQL_DATABASE_CATEGORIAS=categorias_db
MYSQL_DATABASE_IA=ia_db

# Puertos internos de los microservicios (red Docker)
USUARIOS_SERVICE_PORT=3001
# Réplicas usuarios: INSTANCE_ID en docker-compose (usuarios-1, usuarios-2); balanceo en gateway/nginx.conf
TIENDAS_SERVICE_PORT=3002
CATALOGO_SERVICE_PORT=3003
MEDIA_SERVICE_PORT=3004
CATEGORIAS_SERVICE_PORT=3005
IA_SERVICE_PORT=3006
OPS_SERVICE_PORT=3007

# Panel de operaciones (docker.sock): token para Authorization: Bearer en /api/ops/*
# Cambiá este valor antes de exponer el stack; quien tenga el token puede parr/arrancar contenedores de la whitelist.
OPS_PANEL_TOKEN=cambiar_ops_token_seguro

# Puertos publicados en el host (usá estos en el navegador)
# Front:  http://localhost:8280/          Panel ops: http://localhost:8280/ops-panel/
# API GW: http://localhost:3000/          Panel ops: http://localhost:3000/ops-panel/
# http://localhost/ sin número = puerto 80; solo sirve si mapeás 80 explícitamente en compose.
GATEWAY_HOST_PORT=3000
FRONTEND_HOST_PORT=8280

# JWT compartido entre microservicios (misma clave para firmar y validar tokens)
JWT_SECRET=change_this_jwt_secret_with_a_long_random_value

# Token solo servidor-a-servidor: tiendas expone /internal/* y lo consumen catalogo/categorias
INTERNAL_SERVICE_TOKEN=change_this_internal_secret_shared_between_services

# Cloudinary (solo microservicio media)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Groq (microservicio IA en Docker; el front en dev puede usar Vite)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Opcional: solo si corres el front con `npm run dev` y llamás a Groq desde el navegador (no Docker)
# VITE_GROQ_API_KEY=
