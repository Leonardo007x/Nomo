            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Producto actualizado\",\n  \"precio\": 12.5\n}"
            },
            "url": "{{baseUrl}}/api/productos/{{productoId}}"
          }
        },
        {
          "name": "DELETE Producto (JWT)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
