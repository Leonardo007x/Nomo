{
  "info": {
    "_postman_id": "a1b2c3d4-mercado-liebre-api",
    "name": "Mercado Liebre API",
    "description": "Importar en Postman: File → Import → este archivo.\n\nVariables: `baseUrl` (por defecto http://localhost:8080 con Docker). Tras **Login** o **Registro**, se guarda `token` para rutas protegidas.\n\nOpcional: cambia `tiendaId`, `temaId`, `productoId` según tus datos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "tiendaId", "value": "REEMPLAZA_CON_UUID_DE_TU_TIENDA" },
    { "key": "temaId", "value": "REEMPLAZA_CON_UUID_DEL_TEMA" },
    { "key": "productoId", "value": "1" }
  ],
