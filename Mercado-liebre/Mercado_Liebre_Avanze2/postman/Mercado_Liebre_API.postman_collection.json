              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tienda_id\": \"{{tiendaId}}\",\n  \"nombre\": \"Producto de prueba\",\n  \"descripcion\": \"Descripción\",\n  \"precio\": 9.99,\n  \"categoria\": \"General\"\n}"
            },
            "url": "{{baseUrl}}/api/productos"
          }
