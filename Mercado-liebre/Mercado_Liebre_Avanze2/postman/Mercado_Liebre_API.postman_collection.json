            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Registro (alias /api/registro)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.token) pm.collectionVariables.set('token', j.token);",
                  "  if (j.userId) pm.collectionVariables.set('userId', j.userId);",
                  "  else if (j.user && j.user.id) pm.collectionVariables.set('userId', j.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo.usuario@ejemplo.com\",\n  \"password\": \"ClaveSegura1\",\n  \"nombre\": \"Nombre\",\n  \"apellido\": \"Apellido\"\n}"
            },
            "url": "{{baseUrl}}/api/registro"
          }
        },
